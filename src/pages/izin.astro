---
import '../styles/global.css';
---
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Izin ke Kak Aziz</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>
<body>
  <main class="phone">
    <header class="appbar flex items-center gap-3 px-3 py-2.5">
      <div class="icon-chip" style="width:2.25rem;height:2.25rem;background:var(--warning-soft);color:var(--warning);"><i class="fa-solid fa-chalkboard-user"></i></div>
      <div class="flex-1">
        <div class="font-semibold text-[15px] leading-tight" style="color: var(--ink);">Izin ke Kak Aziz</div>
        <div class="text-[11px]" style="color: var(--ink-secondary);">Cukup pilih nama & alasan</div>
      </div>
    </header>

    <!-- Cari nama -->
    <section id="stepSearch" class="flex-1 overflow-y-auto no-scrollbar p-4">
      <label class="ans-label">Cari namamu</label>
      <input id="q" type="text" autocomplete="off" placeholder="Ketik nama kamu…" class="field mt-1" />
      <div id="list" class="mt-3 space-y-2"></div>
    </section>

    <!-- Layar selesai (temporary → destroy) -->
    <section id="stepDone" class="flex-1 hidden flex-col items-center justify-center text-center px-8">
      <div class="w-20 h-20 rounded-[var(--r-xl)] flex items-center justify-center text-4xl mb-4" style="background:var(--accent-soft);color:#16a34a;"><i class="fa-solid fa-circle-check"></i></div>
      <div class="text-xl font-bold" style="color:var(--ink);">Izin Terkirim</div>
      <div class="caption mt-1.5 mb-6">Terima kasih, izinmu sudah sampai ke Kak Aziz. Kamu boleh menutup halaman ini.</div>
      <button id="btnCloseTab" class="btn btn-primary !px-8">Tutup</button>
    </section>
  </main>

  <script>
    import { api, openIzinDrawer, logError } from '../lib/api.js';

    const esc = (s) => (s || '').replace(/[&<>]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
    const stepSearch = document.getElementById('stepSearch');
    const stepDone = document.getElementById('stepDone');
    const listEl = document.getElementById('list');
    const qEl = document.getElementById('q');
    let allStudents = [];

    const showSearch = () => { stepDone.classList.add('hidden'); stepDone.classList.remove('flex'); stepSearch.classList.remove('hidden'); };
    const showDone = () => { stepSearch.classList.add('hidden'); stepDone.classList.remove('hidden'); stepDone.classList.add('flex'); };

    function startIzin(student) {
      stepSearch.classList.add('hidden');   // halaman kosong dulu, lalu drawer muncul
      openIzinDrawer({
        studentId: student.id, name: student.name,
        onClose: (ok) => { if (ok) showDone(); else showSearch(); },
      });
    }

    function renderList(items) {
      if (!items.length) { listEl.innerHTML = '<p class="caption text-center py-4">Nama tidak ditemukan.</p>'; return; }
      listEl.innerHTML = items.slice(0, 30).map(s =>
        `<button data-id="${s.id}" data-name="${esc(s.name)}" class="card card-interactive w-full text-left px-3.5 py-3 flex items-center gap-3">
          <span class="icon-chip" style="background:var(--accent-soft);color:var(--accent);"><i class="fa-solid fa-user"></i></span>
          <span><span class="section-title block">${esc(s.name)}</span><span class="caption">${esc(s.grade || '')}</span></span>
        </button>`).join('');
    }

    qEl.addEventListener('input', () => {
      const q = qEl.value.trim().toLowerCase();
      if (!q) { listEl.innerHTML = ''; return; }
      renderList(allStudents.filter(s => (s.name || '').toLowerCase().includes(q)));
    });
    listEl.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-id]'); if (!btn) return;
      startIzin({ id: btn.dataset.id, name: btn.dataset.name });
    });
    document.getElementById('btnCloseTab').addEventListener('click', () => { window.close(); location.href = 'about:blank'; });

    // Muat daftar siswa + preselect via ?sid=&name=
    (async () => {
      try { const res = await api('/api/student/public/students'); allStudents = res.data || []; }
      catch (ex) { logError('Gagal memuat siswa', ex.message); listEl.innerHTML = '<p class="caption text-center py-4">Gagal memuat data. Coba refresh.</p>'; }
      const p = new URLSearchParams(location.search);
      const sid = p.get('sid');
      if (sid) {
        const found = allStudents.find(s => s.id === sid);
        startIzin({ id: sid, name: found ? found.name : (p.get('name') || 'Kamu') });
      }
    })();
  </script>
</body>
</html>
