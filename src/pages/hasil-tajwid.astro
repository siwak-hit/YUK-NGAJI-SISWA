---
import '../styles/global.css';
---
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title>Hasil Tajwid</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <style>
    .tj-tbl { width:100%; border-collapse:collapse; font-size:13px; }
    .tj-tbl th,.tj-tbl td { border:1px solid var(--hairline,#e5e7eb); padding:8px; text-align:left; vertical-align:top; }
    .tj-tbl th { background:var(--surface-sunken,#f5f5f5); font-weight:700; }
    .big { font-size:52px; font-weight:800; line-height:1; }
    .badge { font-size:10px; font-weight:700; padding:1px 7px; border-radius:999px; }
    .chat-row { display:flex; gap:8px; align-items:flex-start; }
    .chat-ava { width:36px; height:36px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center;
      background:var(--accent-soft,#dcfce7); color:var(--accent-strong,#166534); font-size:16px; }
    .chat-bubble { background:#fff; border:1px solid var(--hairline,#e5e7eb); border-radius:4px 16px 16px 16px;
      padding:12px 14px; box-shadow:0 2px 10px rgba(0,0,0,.05); max-width:100%; flex:1; }
  </style>
</head>
<body>
  <main class="phone">
    <header class="appbar flex items-center gap-3 px-3 py-2.5">
      <div class="icon-chip" style="width:2.25rem;height:2.25rem;background:var(--accent-soft,#dcfce7);color:var(--accent-strong,#166534);"><i class="fa-solid fa-book-quran"></i></div>
      <div class="flex-1">
        <div class="font-semibold text-[15px] leading-tight" style="color:var(--ink);">Hasil Latihan Tajwid</div>
        <div class="text-[11px]" id="sub" style="color:var(--ink-secondary);">Memuat…</div>
      </div>
    </header>

    <section class="flex-1 overflow-y-auto no-scrollbar p-4">
      <div id="loading" class="text-center" style="padding:40px 0;color:var(--ink-secondary)">Memuat hasil…</div>
      <div id="content" hidden>
        <div class="chat-row">
          <div class="chat-ava"><i class="fa-solid fa-chalkboard-user"></i></div>
          <div class="chat-bubble">
            <p style="font-weight:700">Hasil Latihan Tajwidmu 📖</p>
            <p class="text-[12px]" id="bubSub" style="color:var(--ink-secondary)"></p>
            <div style="text-align:center;margin:10px 0 4px">
              <div class="text-[11px]" style="color:var(--ink-secondary)">Nilai rata-rata</div>
              <div class="big" id="avg">—</div>
            </div>
            <table class="tj-tbl"><thead><tr><th>Ayat</th><th>Nilai</th><th>Catatan guru</th></tr></thead><tbody id="rows"></tbody></table>
            <p class="text-[11px] mt-2" style="color:var(--ink-secondary)">Nilai bertanda <span class="badge" style="background:#dcfce7;color:#166534">final</span> sudah dikoreksi guru.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const p = new URLSearchParams(location.search);
    const e = p.get('e'), s = p.get('s');
    const color = (v) => v == null ? '#9ca3af' : v >= 80 ? '#16a34a' : v >= 50 ? '#f59e0b' : '#dc2626';

    async function load() {
      if (!e || !s) { document.getElementById('loading').textContent = 'Link tidak valid.'; return; }
      try {
        const j = await (await fetch(`${API_URL}/api/tajwid/public/result/${e}/${s}`)).json();
        if (j.status !== 'success') throw new Error(j.message);
        const d = j.data;
        document.getElementById('sub').textContent = `${d.student_name || ''} · ${d.items.length} ayat`;
        document.getElementById('bubSub').textContent = `Untuk ${d.student_name || 'kamu'} · ${d.items.length} ayat`;
        const avg = document.getElementById('avg');
        avg.textContent = d.avg ?? '—'; avg.style.color = color(d.avg);
        document.getElementById('rows').innerHTML = d.items.map(it => `
          <tr>
            <td>Ayat ${it.ayah_no ?? '-'}</td>
            <td><b style="color:${color(it.score)}">${it.score ?? '—'}</b>
              <span class="badge" style="background:${it.is_final ? '#dcfce7' : '#fef3c7'};color:${it.is_final ? '#166534' : '#854d0e'}">${it.is_final ? 'final' : 'sementara'}</span></td>
            <td>${it.teacher_note || '<span style="color:#9ca3af">—</span>'}</td>
          </tr>`).join('');
        document.getElementById('loading').hidden = true;
        document.getElementById('content').hidden = false;
      } catch (err) { document.getElementById('loading').textContent = 'Gagal: ' + err.message; }
    }
    load();
  </script>
</body>
</html>
